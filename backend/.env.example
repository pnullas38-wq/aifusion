# VITALIS backend — copy to `.env` next to this file (see docs/WHATSAPP_CONSENT.md).

GEMINI_API_KEY=

# CORS (comma-separated origins, or * for dev)
ALLOWED_ORIGINS=http://localhost:3000

# --- Twilio WhatsApp (consent + report send) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox or production sender (whatsapp: prefix recommended)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Alias supported:
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Public URL Twilio POSTs to — MUST match the URL configured in Twilio Console
# exactly (scheme, host, path, no trailing slash issues — use the same string Twilio uses).
# Alias: WEBHOOK_URL
TWILIO_WEBHOOK_PUBLIC_URL=https://YOUR_SUBDOMAIN.ngrok-free.app/api/whatsapp/webhook

# Optional: where to persist whatsapp_store.json (default: backend/data).
# On serverless platforms, the default path may be read-only; use a writable volume or
# the app will fall back to /tmp if it detects a serverless runtime.
WHATSAPP_DATA_DIR=

# Optional (dev only): disable Twilio signature validation for local testing.
# Never enable in production.
TWILIO_SKIP_SIGNATURE_VALIDATION=
